apiVersion: v1
kind: Service
metadata:
  name: gitlab-nodeport
  namespace: gitlab
spec:
  type: NodePort
  selector:
    app: webservice
    release: gitlab
  ports:
    - port: 8080
      targetPort: 8080
      nodePort: {{ gitlab_pod_port }}

---
apiVersion: v1
kind: Service
metadata:
  name: argocd-server-nodeport
  namespace: argocd
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: argocd-server
  ports:
    - port: 443
      targetPort: 8080
      nodePort: {{ argocd_pod_port }} 

---
apiVersion: v1
kind: Service
metadata:
  name: wil-app-nodeport
  namespace: dev
spec:
  type: NodePort
  selector:
    app: wil-app
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30090