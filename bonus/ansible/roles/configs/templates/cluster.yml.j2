apiVersion: k3d.io/v1alpha5
kind: Simple
metadata:
  name: "{{ k3d_cluster_name }}"
servers: 1
agents: 1
image: docker.io/rancher/k3s:v1.31.5-k3s1
ports:
  - port: 8080:{{ argocd_node_port }}
    nodeFilters:
      - loadbalancer
  - port: 8081:{{ gitea_node_port }}
    nodeFilters:
      - loadbalancer
  - port: 8888:{{ wil_node_port }}
    nodeFilters:
      - loadbalancer
